generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  concepts   Concept[]
  revisions  Revision[]
  materials  Material[]
}

model Concept {
  id          String   @id @default(cuid())
  name        String
  description String?
  topic       String
  retention   Float    @default(100)
  lastRevised DateTime @default(now())
  createdAt   DateTime @default(now())

  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  revisions Revision[]
  quizItems QuizItem[]
}

model Revision {
  id        String   @id @default(cuid())
  score     Float
  revisedAt DateTime @default(now())

  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  conceptId String
  concept   Concept @relation(fields: [conceptId], references: [id], onDelete: Cascade)
}

model Material {
  id        String   @id @default(cuid())
  title     String
  type      String
  url       String?
  content   String?
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model QuizItem {
  id         String   @id @default(cuid())
  question   String
  options    String[]
  answer     Int
  difficulty String   @default("medium")
  createdAt  DateTime @default(now())

  conceptId String
  concept   Concept @relation(fields: [conceptId], references: [id], onDelete: Cascade)
}